{
  "name": "code-command-center",
  "version": "1.0.79",
  "description": "Code Command Center - Manage Claude Code sessions",
  "author": {
    "name": "Adam Gardelov",
    "email": "adam@gardelov.com"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "pnpm run typecheck && electron-vite build",
    "rebuild": "electron-rebuild -f -w node-pty",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:mac": "pnpm run build && electron-builder --mac --publish never",
    "build:linux": "pnpm run build && electron-builder --linux --publish never",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@electron-toolkit/preload": "3.0.2",
    "@electron-toolkit/utils": "4.0.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-unicode-graphemes": "0.4.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "lucide-react": "1.8.0",
    "node-pty": "1.1.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "semver": "7.7.4",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "3.1.0",
    "@electron-toolkit/tsconfig": "2.0.0",
    "@electron/rebuild": "4.0.4",
    "@tailwindcss/vite": "4.2.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/semver": "7.7.1",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "41.2.0",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "eslint": "10.2.0",
    "prettier": "3.8.3",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "lzma-native",
      "node-pty"
    ]
  }
}
